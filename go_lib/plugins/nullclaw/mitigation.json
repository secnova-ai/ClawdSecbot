  {
    "risk_id": "nullclaw_1click_rce_vulnerability",
    "mitigation": {
      "type": "suggestion",
      "title": "1-click RCE漏洞修复建议",
      "description": "此漏洞为严重的远程代码执行漏洞（CVSS 10.0），需要升级OpenClaw版本或手动应用修复补丁。",
      "suggestions": [
        {
          "priority": "P0",
          "category": "立即措施",
          "items": [
            {
              "action": "升级OpenClaw版本",
              "detail": "执行命令检查当前版本：nullclaw --version\n建议升级到包含修复的最新版本（>= 2026.1.24-1）",
              "command": "nullclaw --version"
            },
            {
              "action": "禁用gatewayUrl参数覆盖",
              "detail": "修改 ui/src/ui/app-settings.ts 文件，删除或禁用 applySettingsFromUrl 函数中的 gatewayUrl 参数读取逻辑，或添加域名白名单验证"
            },
            {
              "action": "添加WebSocket Origin验证",
              "detail": "在 src/gateway/auth.ts 的 authorizeGatewayConnect 函数中添加 Origin 白名单验证，拒绝来自非授权域名的连接"
            },
            {
              "action": "修改Token存储方式",
              "detail": "将 localStorage 改为 sessionStorage 存储token，降低跨站泄露风险（ui/src/ui/storage.ts）"
            }
          ]
        },
        {
          "priority": "P1",
          "category": "短期措施",
          "items": [
            {
              "action": "引入安全响应头",
              "detail": "在服务器配置中添加：\nContent-Security-Policy: default-src 'self'; connect-src 'self' wss://yourdomain.com\nX-Frame-Options: DENY\nStrict-Transport-Security: max-age=31536000"
            },
            {
              "action": "实施Gateway URL白名单",
              "detail": "在配置文件中定义允许的Gateway URL列表，拒绝连接到非白名单地址"
            },
            {
              "action": "添加URL修改警告",
              "detail": "在 UI 层检测 gatewayUrl 变化时弹出安全警告，要求用户确认"
            }
          ]
        },
        {
          "priority": "P2",
          "category": "长期措施",
          "items": [
            {
              "action": "定期安全审计",
              "detail": "建立定期安全扫描机制（每周自动化扫描、每月代码审查、每季度渗透测试）"
            },
            {
              "action": "安全监控",
              "detail": "监控异常的Gateway URL连接、异常Origin连接、异常token使用等行为"
            },
            {
              "action": "安全培训",
              "detail": "对开发人员进行安全编码培训，建立漏洞报告流程"
            }
          ]
        }
      ]
    }
  }
]
